# Database
DATABASE_URL=postgresql+asyncpg://rolesignal:rolesignal_dev@localhost:5432/rolesignal

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173

# Auth
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM Configuration (model-agnostic)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# OpenAI Realtime — Voice interviews (separate key)
OPENAI_REALTIME_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview
OPENAI_REALTIME_VOICE=alloy
